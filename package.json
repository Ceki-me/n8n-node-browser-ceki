{
  "name": "@ceki/n8n-nodes-ceki",
  "version": "0.1.2",
  "description": "Rent real human browsers in n8n — anti-bot scraping, human-solved captchas, geo-targeting, and contract-based hiring of agents and humans. Powered by Ceki.",
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "ceki",
    "browser",
    "automation",
    "web-automation",
    "rent",
    "anti-bot",
    "captcha",
    "scraping",
    "scraper",
    "geo",
    "human-browser",
    "ai-agents",
    "rpa"
  ],
  "license": "MIT",
  "author": "Ceki (https://ceki.me)",
  "homepage": "https://browser.ceki.me",
  "repository": "github:Ceki-me/n8n-nodes-ceki",
  "bugs": {
    "url": "https://github.com/Ceki-me/n8n-nodes-ceki/issues"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc && node scripts/copy-icons.js",
    "typecheck": "tsc --noEmit",
    "dev": "tsc --watch",
    "lint": "echo 'No linter configured - add eslint if needed'",
    "release": "npm run build && npm version --git-tag-version true"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/*.credentials.js"
    ],
    "nodes": [
      "dist/nodes/**/*.node.js"
    ]
  },
  "dependencies": {
    "@ceki/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "n8n-workflow": "*",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}
